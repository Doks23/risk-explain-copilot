# Copy this file to .env and fill in one provider.

# Gemini through the OpenAI-compatible endpoint.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional OpenAI-compatible provider. If both OpenAI and Gemini keys are set,
# the app uses OPENAI_API_KEY first.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
