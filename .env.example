# Copy this file to .env and fill in one provider.
# The same key also drives document embeddings for the RAG knowledge base (docs/).
# Without a key, chat falls back to deterministic SQL and the knowledge base is not indexed.

# Gemini through the OpenAI-compatible endpoint.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional OpenAI-compatible provider. If both OpenAI and Gemini keys are set,
# the app uses OPENAI_API_KEY first.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
